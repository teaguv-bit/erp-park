# =====================================================================
# ProjetoTRML — ERP Local — exemplo de variáveis de ambiente
# Copie para um arquivo .env LOCAL (NUNCA versionado) e preencha os valores.
# Nenhum valor real deve ser commitado neste repositório.
# =====================================================================

# ---- PostgreSQL (obrigatório p/ backend local) ----
PGHOST=
PGPORT=5432
PGDATABASE=trml_erp
PGUSER=
PGPASSWORD=

# ---- Tiny API v2 (obrigatório — backend levanta erro sem TINY_TOKEN) ----
TINY_TOKEN=
TINY_BASE_URL=
TINY_TIMEOUT_SECONDS=

# ---- Tiny API v3 / OAuth (integrações v3) ----
TINY_V3_CLIENT_ID=
TINY_V3_CLIENT_SECRET=
TINY_V3_ACCESS_TOKEN=
TINY_V3_AUTH_URL=
TINY_V3_TOKEN_URL=
TINY_V3_BASE_URL=
TINY_V3_REDIRECT_URI=
TINY_V3_OAUTH_SCOPE=
TINY_V3_OAUTH_SECRET=
TINY_V3_STOCK_PATH_TEMPLATE=
TINY_V3_TIMEOUT_SECONDS=

# ---- Google Cloud / BigQuery (backend de produção api.py) ----
GCP_PROJECT_ID=
BQ_DATASET_ID=tiny_orcamento
BQ_LOCATION=US

# ---- Service accounts / credenciais (NUNCA inline no repo) ----
# Forneça via arquivo fora do repo ou variável; aqui apenas o nome.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_JSON_B64=

# ---- Autenticação local ----
ERP_LOCAL_AUTH_JWT_SECRET=
ERP_LOCAL_AUTH_TOKEN_TTL_HOURS=12
ERP_LOCAL_AUTH_PBKDF2_ITERATIONS=

# ---- Regras de acesso / negócio ----
ADMIN_EMAILS=
ALLOWED_EMAILS=
EXPEDITION_EMAILS=
SELLER_EMAIL_MAP_JSON=
SELLER_EMAIL_MAP_JSON_B64=
MAX_DISCOUNT_PCT=35
OPS_SYNC_KEY=
ERP_BASE_URL=

# ---- Flags de funcionalidade ----
ENABLE_TINY_STATUS_SYNC_LOCAL=true
ENABLE_TINY_V3_SEPARATION_SYNC=
ENABLE_OLIST_LINK_UI_FIX=

# ---- Olist UI (automação opcional) ----
OLIST_UI_EMAIL=
OLIST_UI_PASSWORD=
OLIST_UI_HEADLESS=

# =====================================================================
# Frontend (Vite) — prefixo VITE_ exposto ao client.
# Sem estes, o ERP roda em LOCAL_AUTH_MODE (login local, sem Firebase).
# =====================================================================
VITE_FB_API_KEY=
VITE_FB_AUTH_DOMAIN=
VITE_FB_PROJECT_ID=
VITE_FB_APP_ID=
