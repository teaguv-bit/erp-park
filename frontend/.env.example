# Frontend (Vite) — variáveis de ambiente de exemplo.
# Copie para `.env` / `.env.local` e ajuste conforme o ambiente.
# OBS.: somente variáveis com prefixo VITE_ são expostas ao bundle do front.

# ---------------------------------------------------------------------------
# Conferência da separação + Foto (feature gated, aditiva).
# ---------------------------------------------------------------------------
# IMPORTANTE: nada disto "acende" enquanto o backend não expuser a capability
# `me().features.conferencia = true`. Sem ela, o front coage HARD para 'off'
# (legado byte-a-byte), ignorando estas variáveis e o override de localStorage.

# Modo base da etapa de conferência: off | soft | strict  (default: off)
#   off    -> fluxo legado (sem conferência, sem foto).
#   soft   -> piloto sem tablet: foto opcional, etiqueta no mesmo timing de hoje.
#   strict -> com tablet: foto obrigatória, etiqueta só após a conferência.
VITE_SEP_CONFERENCIA_MODE=off

# Allowlist de operadores (logins separados por vírgula). Um operador na lista
# entra em SOFT por padrão (STRICT continua opt-in via VITE_SEP_CONFERENCIA_MODE
# ou via override por dispositivo no localStorage `sep_conferencia_mode`).
# Ex.: VITE_SEP_CONFERENCIA_OPERATORS=daiana,josiel
VITE_SEP_CONFERENCIA_OPERATORS=

# Override por dispositivo (escape hatch de QA): chave de localStorage
# `sep_conferencia_mode` com valor off|soft|strict. Documentado aqui apenas
# como referência — não é uma variável de ambiente. Continua subordinado à
# coerção dura (capability do backend).
